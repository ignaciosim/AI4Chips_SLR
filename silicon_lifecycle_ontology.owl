    </owl:Class>
    <owl:Class rdf:about="http://silicon-lifecycle.org/ontology#process_optimization">
        <rdfs:subClassOf rdf:resource="http://silicon-lifecycle.org/ontology#ChipDesignTask" />
        <rdfs:label>Process Optimization</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://silicon-lifecycle.org/ontology#test_generation">
        <rdfs:subClassOf rdf:resource="http://silicon-lifecycle.org/ontology#ChipDesignTask" />
        <rdfs:label>Test Generation</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://silicon-lifecycle.org/ontology#fault_diagnosis">
        <rdfs:subClassOf rdf:resource="http://silicon-lifecycle.org/ontology#ChipDesignTask" />
        <rdfs:label>Fault Diagnosis</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://silicon-lifecycle.org/ontology#reliability_analysis">
        <rdfs:subClassOf rdf:resource="http://silicon-lifecycle.org/ontology#ChipDesignTask" />
        <rdfs:label>Reliability Analysis</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://silicon-lifecycle.org/ontology#thermal_management">
        <rdfs:subClassOf rdf:resource="http://silicon-lifecycle.org/ontology#ChipDesignTask" />
        <rdfs:label>Thermal Management</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://silicon-lifecycle.org/ontology#security_analysis">
        <rdfs:subClassOf rdf:resource="http://silicon-lifecycle.org/ontology#ChipDesignTask" />
        <rdfs:label>Security Analysis</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://silicon-lifecycle.org/ontology#neural_accelerator">
        <rdfs:subClassOf rdf:resource="http://silicon-lifecycle.org/ontology#HardwareArtifact" />
        <rdfs:label>Neural Network Accelerator</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://silicon-lifecycle.org/ontology#in_memory_computing">
