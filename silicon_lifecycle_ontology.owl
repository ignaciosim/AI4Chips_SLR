    </owl:Class>
    <owl:Class rdf:about="http://silicon-lifecycle.org/ontology#neuromorphic_chip">
        <rdfs:subClassOf rdf:resource="http://silicon-lifecycle.org/ontology#HardwareArtifact" />
        <rdfs:label>Neuromorphic Chip</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://silicon-lifecycle.org/ontology#fpga_accelerator">
        <rdfs:subClassOf rdf:resource="http://silicon-lifecycle.org/ontology#HardwareArtifact" />
