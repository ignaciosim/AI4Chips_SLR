    </owl:Class>
    <owl:Class rdf:about="http://silicon-lifecycle.org/ontology#lithography_optimization">
        <rdfs:subClassOf rdf:resource="http://silicon-lifecycle.org/ontology#ChipDesignTask" />
        <rdfs:label>Lithography Optimization</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://silicon-lifecycle.org/ontology#hotspot_detection">
        <rdfs:subClassOf rdf:resource="http://silicon-lifecycle.org/ontology#ChipDesignTask" />
        <rdfs:label>Hotspot Detection</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://silicon-lifecycle.org/ontology#defect_detection">
        <rdfs:subClassOf rdf:resource="http://silicon-lifecycle.org/ontology#ChipDesignTask" />
