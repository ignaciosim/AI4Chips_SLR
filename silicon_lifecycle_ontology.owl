    </owl:Class>
    <owl:Class rdf:about="http://silicon-lifecycle.org/ontology#specialized_architecture">
        <rdfs:subClassOf rdf:resource="http://silicon-lifecycle.org/ontology#HardwareArtifact" />
        <rdfs:label>Specialized AI Architecture</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://silicon-lifecycle.org/ontology#dnn_inference">
        <rdfs:subClassOf rdf:resource="http://silicon-lifecycle.org/ontology#AIWorkload" />
        <rdfs:label>DNN Inference</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://silicon-lifecycle.org/ontology#dnn_training">
        <rdfs:subClassOf rdf:resource="http://silicon-lifecycle.org/ontology#AIWorkload" />
        <rdfs:label>DNN Training</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://silicon-lifecycle.org/ontology#transformer_inference">
        <rdfs:subClassOf rdf:resource="http://silicon-lifecycle.org/ontology#AIWorkload" />
        <rdfs:label>Transformer Inference</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://silicon-lifecycle.org/ontology#spiking_execution">
        <rdfs:subClassOf rdf:resource="http://silicon-lifecycle.org/ontology#AIWorkload" />
        <rdfs:label>Spiking NN Execution</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="http://silicon-lifecycle.org/ontology#generic_ai_workload">
        <rdfs:subClassOf rdf:resource="http://silicon-lifecycle.org/ontology#AIWorkload" />
        <rdfs:label>Generic AI Workload</rdfs:label>
    </owl:Class>
    <owl:NamedIndividual rdf:about="http://silicon-lifecycle.org/ontology#design">
        <rdf:type rdf:resource="http://silicon-lifecycle.org/ontology#LifecyclePhase" />
        <rdfs:label>Design</rdfs:label>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://silicon-lifecycle.org/ontology#fabrication">
        <rdf:type rdf:resource="http://silicon-lifecycle.org/ontology#LifecyclePhase" />
        <rdfs:label>Fabrication</rdfs:label>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://silicon-lifecycle.org/ontology#packaging">
        <rdf:type rdf:resource="http://silicon-lifecycle.org/ontology#LifecyclePhase" />
        <rdfs:label>Packaging &amp; Assembly</rdfs:label>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="http://silicon-lifecycle.org/ontology#in_field">
        <rdf:type rdf:resource="http://silicon-lifecycle.org/ontology#LifecyclePhase" />
        <rdfs:label>In-Field Operation</rdfs:label>
    </owl:NamedIndividual>
</rdf:RDF>
